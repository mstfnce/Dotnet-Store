@model Cart
@{
    ViewData["Title"] = "Sepet";
    var subtotal = Model.AraToplam();
    var tax = subtotal * 0.2;
    var total = Model.Toplam();
}

@section Bar {
    @await Component.InvokeAsync("Navbar")
}

<section class="cart-section">
    <div class="container">
        @if (Model.CartItems.Count == 0)
        {
            <div class="empty-cart">
                <div class="empty-cart-icon">
                    <i class="fa-solid fa-cart-shopping"></i>
                </div>
                <h2>Sepetinizde ürün bulunmuyor.</h2>
                <p>Ürünleri inceleyip sepetinize ekleyebilirsiniz.</p>
                <a asp-controller="Urun" asp-action="List" class="hero-btn">
                    Alışverişe Başla <i class="fa-solid fa-arrow-right"></i>
                </a>
            </div>
        }
        else
        {
            <div class="cart-layout">
                <div class="cart-items-panel">
                    <div class="cart-panel-header">
                        <div>
                            <h2>Sepet Ürünleri</h2>
                            <span>@Model.CartItems.Count ürün sepetinizde</span>
                        </div>
                        <a asp-controller="Urun" asp-action="List">Alışverişe Devam Et</a>
                    </div>

                    <div class="cart-items-list">
                        @foreach (var item in Model.CartItems)
                        {
                            var lineTotal = item.Urun.Fiyat * item.Miktar;
                            <article class="cart-item-row">
                                <a asp-controller="Urun" asp-action="Details" asp-route-id="@item.UrunId" class="cart-item-image">
                                    <img src="~/img/@item.Urun.Resim" alt="@item.Urun.UrunAdi">
                                </a>

                                <div class="cart-item-info">
                                    <a asp-controller="Urun" asp-action="Details" asp-route-id="@item.UrunId">
                                        @item.Urun.UrunAdi
                                    </a>
                                    <span>Birim Fiyat: @item.Urun.Fiyat.ToString("C0", new System.Globalization.CultureInfo("tr-TR"))</span>
                                    <div class="cart-item-mobile-total">
                                        @lineTotal.ToString("C0", new System.Globalization.CultureInfo("tr-TR"))
                                    </div>
                                </div>

                                <div class="cart-quantity">
                                    <span>Adet</span>
                                    <strong>@item.Miktar</strong>
                                </div>

                                <div class="cart-line-total">
                                    <span>Toplam</span>
                                    <strong>@lineTotal.ToString("C0", new System.Globalization.CultureInfo("tr-TR"))</strong>
                                </div>

                                <form asp-controller="Cart" asp-action="RemoveItem" method="post" class="cart-remove-form">
                                    <input type="hidden" name="urunId" value="@item.UrunId" />
                                    <input type="hidden" name="miktar" value="@item.Miktar" />
                                    <button type="submit" title="Sepetten kaldır">
                                        <i class="fa-solid fa-trash-can"></i>
                                    </button>
                                </form>
                            </article>
                        }
                    </div>
                </div>

                <aside class="cart-summary-card">
                    <h2>Sipariş Özeti</h2>

                    <div class="summary-row">
                        <span>Ara Toplam</span>
                        <strong>@subtotal.ToString("C0", new System.Globalization.CultureInfo("tr-TR"))</strong>
                    </div>
                    <div class="summary-row">
                        <span>Kargo</span>
                        <strong class="success-text">Ücretsiz</strong>
                    </div>
                    <div class="summary-row">
                        <span>Vergi (%20)</span>
                        <strong>@tax.ToString("C0", new System.Globalization.CultureInfo("tr-TR"))</strong>
                    </div>

                    <div class="summary-total">
                        <span>Toplam</span>
                        <strong>@total.ToString("C0", new System.Globalization.CultureInfo("tr-TR"))</strong>
                    </div>

                    <a asp-controller="Order" asp-action="Checkout" class="checkout-btn">
                        Ödemeye Geç <i class="fa-solid fa-arrow-right"></i>
                    </a>
                    <a asp-controller="Urun" asp-action="List" class="continue-btn">
                        Alışverişe Devam Et
                    </a>

                    <div class="summary-note">
                        <i class="fa-solid fa-shield-halved"></i>
                        <span>Güvenli ödeme ve şifreli checkout.</span>
                    </div>
                </aside>
            </div>
        }
    </div>
</section>
