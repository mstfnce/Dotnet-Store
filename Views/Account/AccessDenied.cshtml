@{
    ViewData["Title"] = "Yetkisiz Erişim";
}

@section Bar {
    @await Component.InvokeAsync("Navbar")
}

<section class="completed-section">
    <div class="container">
        <div class="completed-card">
            <div class="completed-icon danger">
                <i class="fa-solid fa-triangle-exclamation"></i>
            </div>

            <span class="completed-kicker">YETKİSİZ ERİŞİM</span>
            <h1>Yetkisiz Erişim</h1>
            <p>Bu sayfayı görüntülemek için gerekli yetkiye sahip değilsiniz.</p>

            <div class="completed-actions">
                <a asp-controller="Home" asp-action="Index" class="checkout-btn">
                    Anasayfa <i class="fa-solid fa-arrow-right"></i>
                </a>
                <a asp-controller="Account" asp-action="Login" class="continue-btn">
                    Giriş Yap
                </a>
            </div>
        </div>
    </div>
</section>
