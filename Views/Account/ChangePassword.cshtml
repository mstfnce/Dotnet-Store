@model AccountChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
}

@section Bar {
    @await Component.InvokeAsync("Navbar")
}

<section class="account-section">
    <div class="container">
        <div class="account-layout">
            @await Html.PartialAsync("Partials/Site/_AccountSideBar")

            <div class="account-panel">
                <div class="account-panel-header">
                    <h1>Parola Değiştir</h1>
                    <p>Hesabının güvenliği için güçlü bir parola kullan.</p>
                </div>

                <form method="post" asp-controller="Account" asp-action="ChangePassword" class="account-form">
                    <div asp-validation-summary="All" class="checkout-validation"></div>

                    <div class="form-field">
                        <label asp-for="OldPassword"></label>
                        <input asp-for="OldPassword" autocomplete="current-password" />
                        <span asp-validation-for="OldPassword"></span>
                    </div>

                    <div class="form-field">
                        <label asp-for="Password"></label>
                        <input asp-for="Password" autocomplete="new-password" />
                        <span asp-validation-for="Password"></span>
                    </div>

                    <div class="form-field">
                        <label asp-for="ConfirmPassword"></label>
                        <input asp-for="ConfirmPassword" autocomplete="new-password" />
                        <span asp-validation-for="ConfirmPassword"></span>
                    </div>

                    <button type="submit" class="checkout-btn">Kaydet</button>
                </form>
            </div>
        </div>
    </div>
</section>
