@model AccountResetPasswordModel
@{
    ViewData["Title"] = "Parola Sıfırla";
}

@section Bar {
    @await Component.InvokeAsync("Navbar")
}

<section class="auth-section">
    <div class="container">
        <div class="auth-card compact">
            <div class="auth-copy">
                <span class="eyebrow">YENİ PAROLA</span>
                <h1>Parola Sıfırla</h1>
                <p>Hesabın için yeni bir parola belirle.</p>
            </div>

            <form method="post" asp-controller="Account" asp-action="ResetPassword" class="auth-form">
                <div asp-validation-summary="All" class="checkout-validation"></div>
                <input type="hidden" asp-for="Token" />
                <input type="hidden" asp-for="Email" />

                <div class="form-field">
                    <label asp-for="Password"></label>
                    <input asp-for="Password" autocomplete="new-password" />
                    <span asp-validation-for="Password"></span>
                </div>

                <div class="form-field">
                    <label asp-for="ConfirmPassword"></label>
                    <input asp-for="ConfirmPassword" autocomplete="new-password" />
                    <span asp-validation-for="ConfirmPassword"></span>
                </div>

                <button type="submit" class="checkout-btn">Kaydet</button>
            </form>
        </div>
    </div>
</section>
