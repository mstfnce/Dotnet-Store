@{
    ViewData["Title"] = "Şifremi Unuttum";
}

@section Bar {
    @await Component.InvokeAsync("Navbar")
}

<section class="auth-section">
    <div class="container">
        <div class="auth-card compact">
            <div class="auth-copy">
                <span class="eyebrow">PAROLA SIFIRLAMA</span>
                <h1>Şifreni sıfırla</h1>
                <p>E-posta adresini gir, sıfırlama bağlantısını gönderelim.</p>
            </div>

            <form method="post" novalidate asp-controller="Account" asp-action="ForgotPassword" class="auth-form">
                <div class="form-field">
                    <label for="email">Eposta</label>
                    <input type="email" id="email" name="email" autocomplete="email" />
                </div>
                <button type="submit" class="checkout-btn">Gönder</button>
                <div class="auth-links single">
                    <a asp-controller="Account" asp-action="Login">Giriş sayfasına dön</a>
                </div>
            </form>
        </div>
    </div>
</section>
