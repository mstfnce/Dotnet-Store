@model AccountLoginModel
@{
    ViewData["Title"] = "Giriş";
}

@section Bar {
    @await Component.InvokeAsync("Navbar")
}

<section class="auth-section">
    <div class="container">
        <div class="auth-card">
            <div class="auth-copy">
                <span class="eyebrow">HOŞ GELDİN</span>
                <h1>Dotnet Store'a Giriş Yap</h1>
                <p>Siparişlerini takip et, sepetini yönet ve ödemeye daha hızlı devam et.</p>
            </div>

            <form method="post" class="auth-form">
                <div asp-validation-summary="All" class="checkout-validation"></div>

                <div class="form-field">
                    <label asp-for="Email"></label>
                    <input asp-for="Email" autocomplete="email" />
                    <span asp-validation-for="Email"></span>
                </div>

                <div class="form-field">
                    <label asp-for="Password"></label>
                    <input asp-for="Password" autocomplete="current-password" />
                    <span asp-validation-for="Password"></span>
                </div>

                <label class="auth-check">
                    <input asp-for="BeniHatirla" />
                    <span>Beni hatırla</span>
                </label>

                <button type="submit" class="checkout-btn">Giriş Yap</button>
                <div class="auth-links">
                    <a asp-controller="Account" asp-action="ForgotPassword">Şifremi Unuttum</a>
                    <a asp-controller="Account" asp-action="Create">Üye Ol</a>
                </div>
            </form>
        </div>
    </div>
</section>
