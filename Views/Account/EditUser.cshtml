@model AccountEditUserModel
@{
    ViewData["Title"] = "Hesabım";
}

@section Bar {
    @await Component.InvokeAsync("Navbar")
}

<section class="account-section">
    <div class="container">
        <div class="account-layout">
            @await Html.PartialAsync("Partials/Site/_AccountSideBar")

            <div class="account-panel">
                <div class="account-panel-header">
                    <h1>Kullanıcı Bilgileri</h1>
                    <p>Hesap bilgilerini buradan güncelleyebilirsin.</p>
                </div>

                <form method="post" asp-controller="Account" asp-action="EditUser" class="account-form">
                    <div asp-validation-summary="All" class="checkout-validation"></div>

                    <div class="form-field">
                        <label asp-for="AdSoyad"></label>
                        <input asp-for="AdSoyad" autocomplete="name" />
                        <span asp-validation-for="AdSoyad"></span>
                    </div>

                    <div class="form-field">
                        <label asp-for="Email"></label>
                        <input asp-for="Email" autocomplete="email" />
                        <span asp-validation-for="Email"></span>
                    </div>

                    <button type="submit" class="checkout-btn">Kaydet</button>
                </form>
            </div>
        </div>
    </div>
</section>
