@model AccountCreatModel
@{
    ViewData["Title"] = "Üye Ol";
}

@section Bar {
    @await Component.InvokeAsync("Navbar")
}

<section class="auth-section">
    <div class="container">
        <div class="auth-card">
            <div class="auth-copy">
                <span class="eyebrow">HESAP OLUŞTUR</span>
                <h1>Dotnet Store'a Katıl</h1>
                <p>Bilgilerini kaydetmek ve sipariş geçmişini görüntülemek için hesap oluştur.</p>
            </div>

            <form method="post" class="auth-form">
                <div asp-validation-summary="All" class="checkout-validation"></div>

                <div class="form-field">
                    <label asp-for="AdSoyad"></label>
                    <input asp-for="AdSoyad" autocomplete="name" />
                    <span asp-validation-for="AdSoyad"></span>
                </div>

                <div class="form-field">
                    <label asp-for="Email"></label>
                    <input asp-for="Email" autocomplete="email" />
                    <span asp-validation-for="Email"></span>
                </div>

                <div class="form-field">
                    <label asp-for="Password"></label>
                    <input asp-for="Password" autocomplete="new-password" />
                    <span asp-validation-for="Password"></span>
                </div>

                <div class="form-field">
                    <label asp-for="ConfirmPassword"></label>
                    <input asp-for="ConfirmPassword" autocomplete="new-password" />
                    <span asp-validation-for="ConfirmPassword"></span>
                </div>

                <button type="submit" class="checkout-btn">Hesap Oluştur</button>
                <div class="auth-links single">
                    <a asp-controller="Account" asp-action="Login">Zaten hesabım var</a>
                </div>
            </form>
        </div>
    </div>
</section>
