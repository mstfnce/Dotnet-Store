@model List<Slider>
@{
    var slideTitles = new[] {
        "Akıllı telefonlarda süper fırsatlar",
        "Yeni teknoloji ürünlerini keşfet",
        "Seçili ürünlerde avantajlı fiyatlar"
    };
    var slideDescriptions = new[] {
        "Telefon, aksesuar ve elektronik ürünlerde öne çıkan kampanyaları inceleyin.",
        "Günlük kullanım için güçlü, şık ve uygun fiyatlı ürünler Dotnet Store'da.",
        "Sınırlı süreli indirimlerle favori ürünlerinizi daha iyi fiyata alın."
    };
}

<div id="slider" class="store-slider carousel slide" data-bs-ride="carousel">
    <div class="carousel-indicators">

        @{
            int x = 0;
            foreach (var item in Model)
            {
                <button type="button" data-bs-target="#slider" data-bs-slide-to="@x" class="@(x == 0 ? "active" : "")"></button>
                x = x + 1;
            }
        }
    </div>
    <div class="carousel-inner">
        @{
            int y = 0;
            foreach (var item in Model)
            {
                var title = string.IsNullOrWhiteSpace(item.Baslik) || item.Baslik.StartsWith("Slider ")
                    ? slideTitles[y % slideTitles.Length]
                    : item.Baslik;
                var description = string.IsNullOrWhiteSpace(item.Aciklama) || item.Aciklama.StartsWith("Slider ")
                    ? slideDescriptions[y % slideDescriptions.Length]
                    : item.Aciklama;

                <div class="carousel-item @(y == 0 ? "active" : "")">
                    <img src="/img/@item.Resim" alt="@title" class="store-slider-image">
                    <div class="store-slider-content">
                        <span>DOTNET STORE</span>
                        <h2>@title</h2>
                        <p>@description</p>
                        <a asp-controller="Urun" asp-action="List" class="hero-btn">
                            Ürünleri İncele <i class="fa-solid fa-arrow-right"></i>
                        </a>
                    </div>
                </div>
                y += 1;
            }
        }
    </div>
    <button type="button" class="carousel-control-prev" data-bs-target="#slider" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
    </button>
    <button type="button" class="carousel-control-next" data-bs-target="#slider" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
    </button>
</div>
