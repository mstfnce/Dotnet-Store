<section class="top-bar">
    <div class="container">
        <div class="top-bar-grid">
            <a href="/" class="store-brand">
                <span class="brand-icon"><i class="fa-solid fa-bag-shopping"></i></span>
                <span><strong>Dotnet</strong> Store</span>
            </a>

            <form asp-controller="Urun" asp-action="List" method="get" class="search-form">
                <input name="q" type="text" placeholder="Ürün, kategori veya marka ara..." value="@ViewData["q"]">
                <button type="submit" aria-label="Ara"><i class="fa fa-search"></i></button>
            </form>

            <div class="top-actions">
                <button type="button" class="top-action theme-toggle" id="themeToggle" aria-label="Toggle dark theme">
                    <i class="fa-solid fa-moon"></i>
                    <span>Tema</span>
                </button>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-controller="Admin" asp-action="Index" class="top-action admin-action" target="_blank">
                            <i class="fa-solid fa-lock"></i>
                            <span>Admin</span>
                        </a>
                    }
                    <a asp-controller="Account" asp-action="EditUser" class="top-action">
                        <i class="fa-regular fa-user"></i>
                        <span>Hesabım</span>
                    </a>
                    <a asp-controller="Account" asp-action="LogOut" class="top-action">
                        <i class="fa-solid fa-right-from-bracket"></i>
                        <span>Çıkış</span>
                    </a>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="top-action">
                        <i class="fa-regular fa-user"></i>
                        <span>Giriş</span>
                    </a>
                    <a asp-controller="Account" asp-action="Create" class="top-action">
                        <i class="fa-solid fa-user-plus"></i>
                        <span>Üye Ol</span>
                    </a>
                }

                <a href="#" class="top-action">
                    <i class="fa-regular fa-heart"></i>
                    <span>Favoriler</span>
                </a>
                <a asp-controller="Cart" asp-action="Index" class="top-action cart-action">
                    <i class="fa-solid fa-cart-shopping"></i>
                    <span class="cart-count">0</span>
                    <span>Sepet</span>
                </a>
            </div>
        </div>
    </div>
</section>
