@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
}

<nav class="admin-navbar navbar navbar-expand-lg">
    <div class="container">
        <a asp-controller="Admin" asp-action="Index"
           class="navbar-brand @(controller == "Admin" ? "active" : "")">
            <i class="fa-solid fa-bag-shopping"></i>
            Dotnet Admin
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarContent">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <a asp-controller="Kategori" asp-action="Index"
                       class="nav-link @(controller == "Kategori" ? "active" : "")">Kategori</a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Urun" asp-action="Index"
                       class="nav-link @(controller == "Urun" ? "active" : "")">Ürün</a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Slider" asp-action="Index"
                       class="nav-link @(controller == "Slider" ? "active" : "")">Slider</a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Role" asp-action="Index"
                       class="nav-link @(controller == "Role" ? "active" : "")">Role</a>
                </li>
                <li class="nav-item">
                    <a asp-controller="User" asp-action="Index"
                       class="nav-link @(controller == "User" ? "active" : "")">Kullanıcı</a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Order" asp-action="Index" class="nav-link">Sipariş</a>
                </li>
            </ul>
            <ul class="navbar-nav mb-2 mb-lg-0">
                <li class="nav-item">
                    <a href="#" class="nav-link">@User.Identity?.Name</a>
                </li>
                <li class="nav-item">
                    <a asp-controller="Account" asp-action="LogOut" class="nav-link">Çıkış</a>
                </li>
            </ul>
        </div>

    </div>
</nav>
