<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script>
        if (localStorage.getItem("dotnet-store-theme") === "dark") {
            document.documentElement.classList.add("dark-theme");
        }
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css">
        <title>Dotnet Store</title>
    </head>

    <body class="bg-light d-flex flex-column min-vh-100">

        <header>
            @await Html.PartialAsync("Partials/Admin/_Message")
            @await Html.PartialAsync("Partials/Site/_Topbar")

            @RenderSection("Bar", required: false)
        </header>

        <main class="flex-fill">
            @RenderBody()
        </main>

        @await Html.PartialAsync("Partials/Site/_Footer")

        <script src="~/js/fslightbox.js"></script>
        <script src="~/js/site.js"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.3/js/bootstrap.bundle.min.js"></script>
        @await RenderSectionAsync("Scripts", required: false)
    </body>

</html>
