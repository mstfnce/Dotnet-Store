@model Urun

@section Bar {
    @await Component.InvokeAsync("Navbar")
}

@{
    ViewData["Title"] = Model.UrunAdi;
    var benzerUrunler = ViewData["BenzerUrunler"] as List<Urun> ?? new List<Urun>();
    var oldPrice = Model.Fiyat * 1.18;
    var discounts = new[] { "-15%", "-10%", "", "-20%" };
}

<section class="product-detail-section">
    <div class="container">
        <nav class="store-breadcrumb" aria-label="breadcrumb">
            <a asp-controller="Home" asp-action="Index">Anasayfa</a>
            <i class="fa-solid fa-chevron-right"></i>
            <a asp-controller="Urun" asp-action="List">Ürünler</a>
            <i class="fa-solid fa-chevron-right"></i>
            <span>@Model.UrunAdi</span>
        </nav>

        <div class="product-detail-card">
            <div class="detail-gallery">
                <a href="~/img/@Model.Resim" data-type="image" data-fslightbox class="detail-main-image">
                    <span class="discount-badge">-15%</span>
                    <img src="~/img/@Model.Resim" alt="@Model.UrunAdi">
                </a>

                <div class="detail-thumbs">
                    <a href="~/img/@Model.Resim" data-type="image" data-fslightbox>
                        <img src="~/img/@Model.Resim" alt="@Model.UrunAdi" loading="lazy">
                    </a>
                    <a href="~/img/1-big.jpeg" data-type="image" data-fslightbox>
                        <img src="~/img/1.jpeg" alt="@Model.UrunAdi" loading="lazy">
                    </a>
                    <a href="~/img/2-big.jpeg" data-type="image" data-fslightbox>
                        <img src="~/img/2.jpeg" alt="@Model.UrunAdi" loading="lazy">
                    </a>
                    <a href="~/img/3-big.jpeg" data-type="image" data-fslightbox>
                        <img src="~/img/3.jpeg" alt="@Model.UrunAdi" loading="lazy">
                    </a>
                </div>
            </div>

            <article class="detail-info">
                <div class="detail-meta">
                    <span class="stock-badge"><i class="fa-solid fa-check"></i> Stokta</span>
                    <span>Ürün Kodu: @Model.Id</span>
                </div>

                <h1>@Model.UrunAdi</h1>

                <div class="detail-rating">
                    <span class="stars">
                        <i class="fa-solid fa-star"></i>
                        <i class="fa-solid fa-star"></i>
                        <i class="fa-solid fa-star"></i>
                        <i class="fa-solid fa-star"></i>
                        <i class="fa-solid fa-star-half-stroke"></i>
                    </span>
                    <span>4.5 puan</span>
                    <span class="dot-divider"></span>
                    <span>128 değerlendirme</span>
                </div>

                <div class="detail-price-box">
                    <div class="detail-price">
                        <strong>@Model.Fiyat.ToString("C0", new System.Globalization.CultureInfo("tr-TR"))</strong>
                        <del>@oldPrice.ToString("C0", new System.Globalization.CultureInfo("tr-TR"))</del>
                    </div>
                    <p>KDV dahil. Uygun siparişlerde kargo ücretsiz.</p>
                </div>

                <p class="detail-description">
                    @(string.IsNullOrWhiteSpace(Model.Aciklama) ? "Dotnet Store müşterileri için seçilmiş kaliteli teknoloji ürünü." : Model.Aciklama)
                </p>

                <form asp-controller="Cart" asp-action="AddToCart" method="post" class="detail-actions">
                    <input type="hidden" name="urunId" value="@Model.Id" />
                    <label class="quantity-control">
                        <span>Adet</span>
                        <input type="number" name="miktar" value="1" min="1">
                    </label>
                    <button type="submit" class="detail-cart-btn">
                        <i class="fa-solid fa-cart-shopping"></i> Sepete Ekle
                    </button>
                    <a href="#" class="detail-favorite-btn" aria-label="Add to favorites">
                        <i class="fa-regular fa-heart"></i>
                    </a>
                </form>

                <div class="detail-benefits">
                    <div>
                        <i class="fa-solid fa-truck-fast"></i>
                        <span>
                            <strong>Hızlı Teslimat</strong>
                            <small>Mağazadan hızlı gönderim</small>
                        </span>
                    </div>
                    <div>
                        <i class="fa-solid fa-shield-halved"></i>
                        <span>
                            <strong>Güvenli Ödeme</strong>
                            <small>Korumalı ödeme süreci</small>
                        </span>
                    </div>
                    <div>
                        <i class="fa-solid fa-rotate-left"></i>
                        <span>
                            <strong>Kolay İade</strong>
                            <small>Basit iade süreci</small>
                        </span>
                    </div>
                    <div>
                        <i class="fa-solid fa-headset"></i>
                        <span>
                            <strong>Destek</strong>
                            <small>İhtiyacınız olduğunda yardım</small>
                        </span>
                    </div>
                </div>
            </article>
        </div>
    </div>
</section>

@if (benzerUrunler.Count > 0)
{
    <section class="related-products-section">
        <div class="container">
            <div class="section-heading">
                <h2>Benzer Ürünler</h2>
                <a asp-controller="Urun" asp-action="List">Tümünü Gör <i class="fa-solid fa-chevron-right"></i></a>
            </div>

            <div class="related-grid">
                @for (var i = 0; i < benzerUrunler.Count; i++)
                {
                    ViewData["Discount"] = discounts[i % discounts.Length];
                    @await Html.PartialAsync("Partials/Site/_UrunCard", benzerUrunler[i], ViewData)
                }
            </div>
        </div>
    </section>
}
