@model List<Urun>
@{
    ViewData["Title"] = "Ürünler";
    var categories = ViewData["Kategoriler"] as List<Kategori> ?? new List<Kategori>();
    var selectedCategory = ViewData["SelectedCategory"] as string;
    var searchTerm = ViewData["q"] as string;
    var discounts = new[] { "-15%", "-10%", "", "-20%", "", "-15%" };
    var activeCategory = categories.FirstOrDefault(i => i.Url == selectedCategory);
}

@section Bar {
    @await Component.InvokeAsync("Navbar")
}

<section class="catalog-hero">
    <div class="container">
        <div class="catalog-hero-inner">
            <div>
                <h1>@(activeCategory?.KategoriAdi ?? "Tüm Teknoloji Ürünleri")</h1>
                <p>
                    @if (!string.IsNullOrWhiteSpace(searchTerm))
                    {
                        <text>"@searchTerm" araması için bulunan ürünleri inceliyorsunuz.</text>
                    }
                    else
                    {
                        <text>Teknoloji ürünlerini, aksesuarları ve günlük fırsatları tek katalogda inceleyin.</text>
                    }
                </p>
            </div>
        </div>
    </div>
</section>

<section class="catalog-section">
    <div class="container">
        <div class="catalog-layout">
            <aside class="catalog-sidebar">
                <div class="filter-card">
                    <h2>Kategoriler</h2>
                    <a asp-controller="Urun" asp-action="List" class="filter-link @(string.IsNullOrWhiteSpace(selectedCategory) ? "active" : "")">
                        Tüm Ürünler
                    </a>
                    @foreach (var category in categories)
                    {
                        <a href="/urunler/@category.Url" class="filter-link @(selectedCategory == category.Url ? "active" : "")">
                            @category.KategoriAdi
                        </a>
                    }
                </div>

                <div class="filter-card">
                    <h2>Avantajlar</h2>
                    <div class="filter-note"><i class="fa-solid fa-truck-fast"></i> Ücretsiz kargo</div>
                    <div class="filter-note"><i class="fa-solid fa-shield-halved"></i> Güvenli ödeme</div>
                    <div class="filter-note"><i class="fa-solid fa-rotate-left"></i> Kolay iade</div>
                </div>
            </aside>

            <div class="catalog-content">
                <div class="catalog-toolbar">
                    <div>
                        <h2>Öne Çıkan Ürünler</h2>
                        <span>@Model.Count ürün listeleniyor</span>
                    </div>
                    <form asp-controller="Urun" asp-action="List" method="get" class="catalog-search">
                        <input name="q" type="text" value="@searchTerm" placeholder="Ürün ara...">
                        <button type="submit"><i class="fa-solid fa-search"></i></button>
                    </form>
                </div>

                @if (Model.Count == 0)
                {
                    <div class="empty-catalog">
                        <i class="fa-solid fa-magnifying-glass"></i>
                        <h2>Ürün bulunamadı.</h2>
                        <p>Arama kelimesini değiştirerek veya farklı bir kategori seçerek tekrar deneyin.</p>
                        <a asp-controller="Urun" asp-action="List" class="hero-btn">Tüm Ürünler</a>
                    </div>
                }
                else
                {
                    <div class="catalog-grid">
                        @for (var i = 0; i < Model.Count; i++)
                        {
                            ViewData["Discount"] = discounts[i % discounts.Length];
                            @await Html.PartialAsync("Partials/Site/_UrunCard", Model[i], ViewData)
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</section>
