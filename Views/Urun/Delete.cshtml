@model Urun

@{
    Layout = "_AdminLayout";
}

<div class="row">
    <div class="col">
        <div class="card shadow">
            <div class="card-header py-1 d-flex justify-content-between align-items-center">
                <h5 class="card-title">Ürün Sil</h5>
                <a asp-controller="Urun" asp-action="Index" class="btn btn-sm btn-primary">
                    <i class="fa-solid fa-list"></i>
                </a>
            </div>
            <div class="card-body">
                <div class="alert alert-danger">
                    <strong>@Model.UrunAdi</strong> ürününü silmek istediginizden emin misiniz?
                </div>

                <div class="row">
                    <div class="col-md-3 mb-3">
                        <img src="~/img/@Model.Resim" class="img-thumbnail" alt="@Model.UrunAdi" />
                    </div>
                    <div class="col-md-9">
                        <dl class="row mb-4">
                            <dt class="col-sm-3">Id</dt>
                            <dd class="col-sm-9">@Model.Id</dd>

                            <dt class="col-sm-3">Ürün Adı</dt>
                            <dd class="col-sm-9">@Model.UrunAdi</dd>

                            <dt class="col-sm-3">Fiyat</dt>
                            <dd class="col-sm-9">@Model.Fiyat ₺</dd>

                            <dt class="col-sm-3">Açıklama</dt>
                            <dd class="col-sm-9">@Model.Aciklama</dd>

                            <dt class="col-sm-3">Aktif</dt>
                            <dd class="col-sm-9">
                                @if (Model.Aktif)
                                {
                                    <i class="fa-solid fa-circle-check text-success"></i>
                                }
                                else
                                {
                                    <i class="fa-solid fa-circle-xmark text-danger"></i>
                                }
                            </dd>

                            <dt class="col-sm-3">Anasayfa</dt>
                            <dd class="col-sm-9">
                                @if (Model.Anasayfa)
                                {
                                    <i class="fa-solid fa-circle-check text-success"></i>
                                }
                                else
                                {
                                    <i class="fa-solid fa-circle-xmark text-danger"></i>
                                }
                            </dd>
                        </dl>

                        <form asp-controller="Urun" asp-action="DeleteConfirm" method="post">
                            <input type="hidden" name="id" value="@Model.Id">
                            <button type="submit" class="btn btn-danger">Sil</button>
                            <a asp-controller="Urun" asp-action="Index" class="btn btn-secondary">Vazgec</a>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
