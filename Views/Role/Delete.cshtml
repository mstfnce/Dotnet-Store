@model AppRole

@{
    Layout = "_AdminLayout";
}

<div class="row">
    <div class="col">
        <div class="card shadow border-0">
            <div class="card-header py-2 bg-danger text-white d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">
                    <i class="fa-solid fa-triangle-exclamation me-2"></i>Role Sil
                </h5>
                <a asp-controller="Role" asp-action="Index" class="btn btn-sm btn-light">
                    <i class="fa-solid fa-list"></i>
                </a>
            </div>

            <div class="card-body">
                <div class="alert alert-danger d-flex align-items-start gap-3">
                    <i class="fa-solid fa-circle-exclamation fs-4 mt-1"></i>
                    <div>
                        <div class="fw-semibold">Bu islem geri alinamaz.</div>
                        <div>
                            <strong>@Model.Name</strong> rolunu silmek istediginizden emin misiniz?
                        </div>
                    </div>
                </div>

                <div class="border rounded p-3 mb-4 bg-light">
                    <dl class="row mb-0">
                        <dt class="col-sm-2">Id</dt>
                        <dd class="col-sm-10">
                            <span class="badge text-bg-secondary">@Model.Id</span>
                        </dd>

                        <dt class="col-sm-2">Role Adi</dt>
                        <dd class="col-sm-10 mb-0 fw-semibold">@Model.Name</dd>
                    </dl>
                </div>

                <form asp-controller="Role" asp-action="DeleteConfirm" method="post">
                    <input type="hidden" name="id" value="@Model.Id">

                    @if (ViewBag.Users != null && ViewBag.Users.Count > 0)
                    {
                        <div class="alert alert-warning">
                            <div class="fw-semibold mb-2">
                                <i class="fa-solid fa-users me-2"></i>Bu role bagli kullanicilar var.
                            </div>
                            <ul class="mb-0">
                                @foreach (var item in ViewBag.Users)
                                {
                                    <li>@item</li>
                                }
                            </ul>
                        </div>
                    }
                    else
                    {
                        <button type="submit" class="btn btn-danger">
                            <i class="fa-solid fa-trash-can me-1"></i>Sil
                        </button>
                    }

                    <a asp-controller="Role" asp-action="Index" class="btn btn-outline-secondary">
                        Vazgec
                    </a>
                </form>
            </div>
        </div>
    </div>
</div>
