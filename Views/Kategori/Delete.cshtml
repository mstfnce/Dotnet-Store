@model Kategori

@{
    Layout = "_AdminLayout";
}

<div class="row">
    <div class="col">
        <div class="card shadow">
            <div class="card-header py-1 d-flex justify-content-between align-items-center">
                <h5 class="card-title">Kategori Sil</h5>
                <a asp-controller="Kategori" asp-action="Index" class="btn btn-sm btn-primary">
                    <i class="fa-solid fa-list"></i>
                </a>
            </div>
            <div class="card-body ">
                <div class="alert alert-danger">
                    <strong>@Model.KategoriAdi</strong> kategorisini silmek istediginizden emin misiniz?
                </div>

                <dl class="row mb-4">
                    <dt class="col-sm-2">Id</dt>
                    <dd class="col-sm-10">@Model.Id</dd>

                    <dt class="col-sm-2">Kategori Adi</dt>
                    <dd class="col-sm-10">@Model.KategoriAdi</dd>

                    <dt class="col-sm-2">Url</dt>
                    <dd class="col-sm-10">@Model.Url</dd>
                </dl>

                <form asp-controller="Kategori" asp-action="DeleteConfirm" method="post">
                    <input type="hidden" name="id" value="@Model.Id">
                    <button type="submit" class="btn btn-danger">Sil</button>
                    <a asp-controller="Kategori" asp-action="Index" class="btn btn-secondary">Vazgec</a>
                </form>
            </div>
        </div>
    </div>
</div>
