@model string

@section Bar {
    <section class="bg-primary py-3">
        <div class="container">
            <nav>
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item">
                        <a asp-controller="Home" asp-action="Index">Anasayfa</a>
                    </li>
                    <li class="breadcrumb-item active">
                        Sipariş Tamamlandı
                    </li>
                </ol>
            </nav>
        </div>
    </section>
}

<section class="py-4">
    <div class="container">
        <div class="card shadow-sm border-0">
            <div class="card-body text-center py-5">
                <i class="fa-solid fa-circle-check fa-3x text-success mb-3"></i>
                <h1 class="h4 mb-2">Siparişiniz alındı</h1>
                <p class="text-muted mb-4">
                    Sipariş numaranız:
                    <span class="fw-semibold text-dark">#@Model</span>
                </p>

                <div class="d-flex flex-column flex-sm-row justify-content-center gap-2">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                        Alışverişe Devam Et
                    </a>
                    <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-secondary">
                        Sepete Git
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
