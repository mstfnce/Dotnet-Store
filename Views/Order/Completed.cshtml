@model string
@{
    ViewData["Title"] = "Sipariş Tamamlandı";
}

@section Bar {
    @await Component.InvokeAsync("Navbar")
}

<section class="completed-section">
    <div class="container">
        <div class="completed-card">
            <div class="completed-icon">
                <i class="fa-solid fa-check"></i>
            </div>

            <span class="completed-kicker">SİPARİŞ TAMAMLANDI</span>
            <h1>Siparişiniz alındı</h1>
            <p>
                Sipariş numaranız <strong>#@Model</strong>. Sipariş durumunu hesabınızdan takip edebilirsiniz.
            </p>

            <div class="completed-actions">
                <a asp-controller="Urun" asp-action="List" class="checkout-btn">
                    Alışverişe Devam Et <i class="fa-solid fa-arrow-right"></i>
                </a>
                <a asp-controller="Order" asp-action="OrderList" class="continue-btn">
                    Siparişlerim
                </a>
            </div>
        </div>
    </div>
</section>
