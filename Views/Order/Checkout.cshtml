@model OrderCreateModel
@{
    ViewData["Title"] = "Ödeme";
    Cart cart = ViewBag.Cart;
    var subtotal = cart.AraToplam();
    var tax = subtotal * 0.2;
    var total = cart.Toplam();
}

@section Bar {
    @await Component.InvokeAsync("Navbar")
}

<section class="checkout-section">
    <div class="container">
        <nav class="store-breadcrumb" aria-label="breadcrumb">
            <a asp-controller="Home" asp-action="Index">Anasayfa</a>
            <i class="fa-solid fa-chevron-right"></i>
            <a asp-controller="Cart" asp-action="Index">Sepet</a>
            <i class="fa-solid fa-chevron-right"></i>
            <span>Ödeme</span>
        </nav>

        <form method="post" class="checkout-layout">
            <div class="checkout-main">
                <div asp-validation-summary="All" class="checkout-validation"></div>

                <section class="checkout-card">
                    <div class="checkout-card-header">
                        <span>1</span>
                        <div>
                            <h1>Teslimat Bilgileri</h1>
                            <p>Siparişin gönderileceği adres bilgilerini girin.</p>
                        </div>
                    </div>

                    <div class="checkout-form-grid">
                        <div class="form-field full">
                            <label asp-for="AdSoyad"></label>
                            <input asp-for="AdSoyad" autocomplete="name" />
                            <span asp-validation-for="AdSoyad"></span>
                        </div>
                        <div class="form-field">
                            <label asp-for="Sehir"></label>
                            <input asp-for="Sehir" autocomplete="address-level2" />
                            <span asp-validation-for="Sehir"></span>
                        </div>
                        <div class="form-field">
                            <label asp-for="Telefon"></label>
                            <input asp-for="Telefon" autocomplete="tel" />
                            <span asp-validation-for="Telefon"></span>
                        </div>
                        <div class="form-field">
                            <label asp-for="PostaKodu"></label>
                            <input asp-for="PostaKodu" autocomplete="postal-code" />
                            <span asp-validation-for="PostaKodu"></span>
                        </div>
                        <div class="form-field full">
                            <label asp-for="AdresSatiri"></label>
                            <textarea asp-for="AdresSatiri" rows="3" autocomplete="street-address"></textarea>
                            <span asp-validation-for="AdresSatiri"></span>
                        </div>
                        <div class="form-field full">
                            <label asp-for="SiparisNotu"></label>
                            <textarea asp-for="SiparisNotu" rows="3"></textarea>
                            <span asp-validation-for="SiparisNotu"></span>
                        </div>
                    </div>
                </section>

                <section class="checkout-card">
                    <div class="checkout-card-header">
                        <span>2</span>
                        <div>
                            <h2>Ödeme Bilgileri</h2>
                            <p>Test ödeme bilgilerini girerek siparişi tamamlayın.</p>
                        </div>
                    </div>

                    <div class="payment-card-preview">
                        <div>
                            <span>Dotnet Store</span>
                            <strong>Güvenli Ödeme</strong>
                        </div>
                        <i class="fa-solid fa-lock"></i>
                    </div>

                    <div class="checkout-form-grid">
                        <div class="form-field">
                            <label asp-for="CartName">Kart Üzerindeki İsim</label>
                            <input asp-for="CartName" autocomplete="cc-name" />
                            <span asp-validation-for="CartName"></span>
                        </div>
                        <div class="form-field">
                            <label asp-for="CartNumber">Kart Numarası</label>
                            <input asp-for="CartNumber" autocomplete="cc-number" />
                            <span asp-validation-for="CartNumber"></span>
                        </div>
                        <div class="form-field">
                            <label asp-for="CartExpirationMonth">Ay</label>
                            <input asp-for="CartExpirationMonth" autocomplete="cc-exp-month" />
                            <span asp-validation-for="CartExpirationMonth"></span>
                        </div>
                        <div class="form-field">
                            <label asp-for="CartExpirationYear">Yıl</label>
                            <input asp-for="CartExpirationYear" autocomplete="cc-exp-year" />
                            <span asp-validation-for="CartExpirationYear"></span>
                        </div>
                        <div class="form-field">
                            <label asp-for="CartCVV">CVV</label>
                            <input asp-for="CartCVV" autocomplete="cc-csc" />
                            <span asp-validation-for="CartCVV"></span>
                        </div>
                    </div>
                </section>
            </div>

            <aside class="checkout-summary">
                <h2>Sipariş Özeti</h2>

                <div class="checkout-items">
                    @foreach (var item in cart.CartItems)
                    {
                        var lineTotal = item.Urun.Fiyat * item.Miktar;
                        <div class="checkout-item">
                            <img src="~/img/@item.Urun.Resim" alt="@item.Urun.UrunAdi">
                            <div>
                                <strong>@item.Urun.UrunAdi</strong>
                                <span>x @item.Miktar</span>
                            </div>
                            <span>@lineTotal.ToString("C0", new System.Globalization.CultureInfo("tr-TR"))</span>
                        </div>
                    }
                </div>

                <div class="summary-row">
                    <span>Ara Toplam</span>
                    <strong>@subtotal.ToString("C0", new System.Globalization.CultureInfo("tr-TR"))</strong>
                </div>
                <div class="summary-row">
                    <span>Kargo</span>
                    <strong class="success-text">Ücretsiz</strong>
                </div>
                <div class="summary-row">
                    <span>Vergi (%20)</span>
                    <strong>@tax.ToString("C0", new System.Globalization.CultureInfo("tr-TR"))</strong>
                </div>
                <div class="summary-total">
                    <span>Toplam</span>
                    <strong>@total.ToString("C0", new System.Globalization.CultureInfo("tr-TR"))</strong>
                </div>

                <button type="submit" asp-controller="Order" asp-action="Checkout" class="checkout-btn">
                    Siparişi Tamamla <i class="fa-solid fa-arrow-right"></i>
                </button>
                <a asp-controller="Cart" asp-action="Index" class="continue-btn">Sepete Geri Dön</a>

                <div class="summary-note">
                    <i class="fa-solid fa-shield-halved"></i>
                    <span>Ödeme bilgileriniz güvenli şekilde işlenir.</span>
                </div>
            </aside>
        </form>
    </div>
</section>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
